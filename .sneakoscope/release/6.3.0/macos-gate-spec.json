{
  "schema": "sks.macos-menubar-gate-spec.v1",
  "runner": "macos-latest",
  "node": "24",
  "steps": [
    "actions/checkout@v6 with fetch-depth 0",
    "actions/setup-node@v6 with package-manager-cache false",
    "npm ci --ignore-scripts",
    "npm run build:clean --silent",
    "mkdir -p .sneakoscope/reports",
    "node ./dist/scripts/sks-menubar-install-check.js > .sneakoscope/reports/menubar-install.json",
    "node ./dist/scripts/release-macos-menubar-proof.js --install-report .sneakoscope/reports/menubar-install.json"
  ],
  "required_checks": [
    "Swift parse/compile and AppKit link",
    "AppIcon.icns and four status templates",
    "CFBundleIconFile=AppIcon",
    "codesign --verify --deep --strict",
    "idempotent install",
    "previous app rollback",
    "resource SHA-256 build stamp"
  ],
  "artifacts": [
    ".sneakoscope/reports/menubar-install.json",
    ".sneakoscope/reports/release/<version>/macos-menubar-proof.json"
  ]
}
