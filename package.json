{
  "name": "sneakoscope",
  "displayName": "ㅅㅋㅅ",
  "version": "6.1.1",
  "description": "Proof-first Codex trust layer for bounded agent workflows, search visibility evidence, and release integrity gates.",
  "type": "module",
  "homepage": "https://github.com/mandarange/Sneakoscope-Codex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarange/Sneakoscope-Codex.git"
  },
  "bugs": {
    "url": "https://github.com/mandarange/Sneakoscope-Codex/issues"
  },
  "bin": {
    "sks": "dist/bin/sks.js",
    "sneakoscope": "dist/bin/sks.js",
    "sneakoscope-install": "dist/bin/install.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "files": [
    "dist",
    "!dist/*.json",
    "!dist/.sks-build-stamp.json",
    "!dist/build-manifest.json",
    "!dist/**/*.d.ts",
    "!dist/**/*.d.ts.map",
    "!dist/**/*.js.map",
    "!dist/**/*.tsbuildinfo",
    "!dist/**/__tests__",
    "!dist/**/*.test.js",
    "!dist/scripts/*blackbox*.js",
    "!dist/scripts/release-readiness-report.js",
    "!dist/scripts/readme-architecture-imagegen-official-check.js",
    "!dist/scripts/gpt-image-2-real-file-smoke.js",
    "!dist/scripts/official-docs-compat-report.js",
    "!dist/scripts/codex-0-134-official-compat-report.js",
    "!dist/scripts/release-metadata-1-16-check.js",
    "!dist/scripts/release-metadata-1-17-check.js",
    "!dist/scripts/release-metadata-1-19-check.js",
    "!dist/scripts/check-source-runtime.js",
    "!dist/scripts/loop-*-check.js",
    "!dist/scripts/uninstall-inventory-check.js",
    "!dist/scripts/performance-baseline-check.js",
    "!dist/scripts/performance-improvement-report-check.js",
    "!dist/scripts/gate-timing-check.js",
    "!dist/scripts/release-runner-efficiency-check.js",
    "!dist/scripts/command-performance-scorecard-check.js",
    "!dist/scripts/dollar-performance-scorecard-check.js",
    "!dist/scripts/retention-long-run-smoke-check.js",
    "!dist/scripts/ops-maturity-scorecard-check.js",
    "!dist/scripts/naruto-real-parallelism-blackbox.js",
    "!dist/scripts/agent-native-release-gate.js",
    "!dist/scripts/release-parallel-check.js",
    "dist/scripts/doctor-context7-mcp-repair-blackbox.js",
    "dist/scripts/doctor-fix-production-blackbox.js",
    "dist/scripts/doctor-startup-config-repair-blackbox.js",
    "dist/scripts/doctor-supabase-mcp-repair-blackbox.js",
    "dist/scripts/project-skill-dedupe-blackbox.js",
    "dist/scripts/supabase-secret-preservation-blackbox.js",
    "dist/scripts/update-preserves-supabase-keys-blackbox.js",
    "!dist/vendor/openai-codex/rust-v0.131.0",
    "config/codex-releases/rust-v0.144.1.json",
    "config/bench-baseline.json",
    "config/competitor-scorecard-baseline.json",
    "config/perf-budgets.v1.json",
    "release-gates.v2.json",
    "infra-harness-gates.json",
    "runtime-required-scripts.json",
    "schemas",
    "!schemas/codex/app-server-0.144/**",
    "schemas/codex/app-server-0.144/codex_app_server_protocol.v2.schemas.json",
    "!schemas/codex/app-server-0.144-ts/**",
    "crates/sks-core/Cargo.lock",
    "crates/sks-core/Cargo.toml",
    "crates/sks-core/src",
    "docs/demo.tape",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "npm run build:clean",
    "prepack": "npm run build",
    "build:clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('.sneakoscope/cache/tsbuildinfo',{recursive:true,force:true})\" && tsc -p tsconfig.json && node ./dist/scripts/ensure-bin-executable.js && node ./dist/scripts/build-dist.js",
    "build:incremental": "tsc -p tsconfig.json && node ./dist/scripts/ensure-bin-executable.js && node ./dist/scripts/build-dist.js",
    "release:ensure-build": "node -e \"const fs=require('fs'),cp=require('child_process'); if(!fs.existsSync('dist/scripts/release-dist-freshness-check.js')){const npm=process.platform==='win32'?'npm.cmd':'npm'; const r=cp.spawnSync(npm,['run','build:clean','--silent'],{stdio:'inherit'}); process.exit(r.status==null?1:r.status)}\" && node ./dist/scripts/release-dist-freshness-check.js",
    "test": "node ./dist/scripts/canonical-test-runner.js",
    "prepublishOnly": "node ./dist/scripts/prepublish-release-check-or-fast.js --block-lifecycle-publish",
    "runtime:no-src-mjs": "node ./dist/scripts/runtime-no-src-mjs-check.js",
    "runtime:ts-source-of-truth": "node ./dist/scripts/runtime-ts-source-of-truth-check.js",
    "architecture:guard": "node ./dist/scripts/architecture-guard-check.js",
    "runtime:dist-parity": "node ./dist/scripts/runtime-dist-parity-check.js",
    "release:check": "npm run release:check:affected",
    "release:metadata": "node ./dist/scripts/release-metadata-check.js",
    "release:version-truth": "node ./dist/scripts/release-version-truth-check.js",
    "release:dist-freshness": "node ./dist/scripts/release-dist-freshness-check.js",
    "release:provenance": "node ./dist/scripts/release-provenance-check.js",
    "release:gate-script-parity": "node ./dist/scripts/release-gate-script-parity-check.js",
    "ppt:real-imagegen-wiring": "node ./dist/scripts/ppt-real-imagegen-wiring-check.js",
    "ux-review:run-wires-imagegen": "node ./dist/scripts/ux-review-run-wires-imagegen-check.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "schema:check": "node ./dist/scripts/check-runtime-schemas.js",
    "secret:preservation-guard": "node ./dist/scripts/secret-preservation-guard-check.js",
    "postinstall": "node ./dist/bin/sks.js postinstall",
    "doctor:fix-production-blackbox": "node ./dist/scripts/doctor-fix-production-blackbox.js",
    "doctor:startup-config-repair-blackbox": "node ./dist/scripts/doctor-startup-config-repair-blackbox.js",
    "doctor:context7-mcp-repair-blackbox": "node ./dist/scripts/doctor-context7-mcp-repair-blackbox.js",
    "doctor:supabase-mcp-repair-blackbox": "node ./dist/scripts/doctor-supabase-mcp-repair-blackbox.js",
    "codex:0140-capability": "node ./dist/scripts/codex-0140-capability-check.js",
    "codex:0140-feature-probes": "node ./dist/scripts/codex-0140-feature-probes-check.js",
    "native-capability:postcheck": "node ./dist/scripts/native-capability-postcheck-check.js",
    "runtime:ts-rust-boundary": "node ./dist/scripts/runtime-ts-rust-boundary-check.js",
    "codex:permission-profiles": "node ./dist/scripts/codex-permission-profiles-check.js",
    "mcp:tool-naming-parity": "node ./dist/scripts/mcp-tool-naming-parity-check.js",
    "runtime:no-tmux": "node ./dist/scripts/runtime-no-tmux-check.js",
    "zellij:capability": "node ./dist/scripts/zellij-capability-check.js",
    "zellij:layout-valid": "node ./dist/scripts/zellij-layout-valid-check.js",
    "zellij:doctor-readiness": "node ./dist/scripts/zellij-doctor-readiness-check.js",
    "codex:project-config-policy-splitter": "node ./dist/scripts/codex-project-config-policy-splitter-check.js",
    "migration:upgrade-safety": "node ./dist/scripts/legacy-upgrade-matrix-check.js",
    "secret:supabase-preservation-blackbox": "node ./dist/scripts/supabase-secret-preservation-blackbox.js",
    "update:preserves-supabase-keys": "node ./dist/scripts/update-preserves-supabase-keys-blackbox.js",
    "packcheck": "for d in bin test; do [ -d \"$d\" ] && find \"$d\" -name '*.mjs' -print0; done | xargs -0 -n1 node --check && npm run runtime:no-src-mjs",
    "changelog:check": "node ./dist/scripts/changelog-check.js",
    "cli-entrypoint:check": "node ./dist/scripts/check-cli-entrypoint.js",
    "legacy-free:check": "node ./dist/scripts/check-legacy-free.js",
    "architecture:check": "node ./dist/scripts/check-architecture.js",
    "route-modularity:check": "node ./dist/scripts/check-route-modularity.js",
    "command-budget:check": "node ./dist/scripts/check-command-module-budget.js",
    "pipeline-budget:check": "node ./dist/scripts/check-pipeline-budget.js",
    "pipeline-runtime:check": "node ./dist/scripts/check-pipeline-runtime.js",
    "sizecheck": "node ./dist/scripts/sizecheck.js",
    "publish-tag:check": "node ./dist/scripts/check-publish-tag.js",
    "feature:check": "node ./dist/bin/sks.js features check --json",
    "feature-quality:check": "node ./dist/scripts/check-feature-quality.js --release",
    "naruto:sim-active-pool-runtime": "node ./dist/scripts/naruto-real-active-pool-runtime-check.js",
    "core-skill:no-drift": "node ./dist/scripts/core-skill-no-drift-check.js",
    "skill:dedupe-blackbox": "node ./dist/scripts/project-skill-dedupe-blackbox.js",
    "release:check:affected": "npm run release:ensure-build --silent && node ./dist/scripts/release-gate-dag-runner.js --preset affected --changed-since auto --sla 5m",
    "release:real-check": "node ./dist/scripts/release-real-check.js",
    "release:check:fast": "npm run release:ensure-build --silent && node ./dist/scripts/release-gate-dag-runner.js --preset fast --changed-since auto --sla 5m",
    "release:check:confidence": "npm run release:ensure-build --silent && node ./dist/scripts/release-gate-dag-runner.js --preset confidence --changed-since auto --sla 5m",
    "release:check:full": "node ./dist/bin/sks.js doctor --fix --yes --json --report-file .sneakoscope/reports/release-check-full-doctor.json >/dev/null && npm run build:clean --silent && npm test --silent && node ./dist/scripts/release-gate-dag-runner.js --preset release --full && node ./dist/scripts/release-real-check.js --skip-release-check && npm run release:dist-freshness --silent && node ./dist/scripts/release-check-stamp.js write --preset release --full",
    "publish:packlist-performance": "node ./dist/scripts/packlist-performance-check.js",
    "publish:dry-run-performance": "node ./dist/scripts/npm-publish-performance-check.js",
    "publish:dry": "npm run publish:prep-ignore-scripts && npm pack --dry-run --ignore-scripts --json",
    "publish:verify-ignore-scripts": "npm run release:dist-freshness --silent && npm run release:version-truth --silent && npm run publish:packlist-performance --silent && node ./dist/scripts/package-published-contract-check.js && npm run publish-tag:check --silent",
    "publish:prep-ignore-scripts": "node ./dist/scripts/release-check-stamp.js verify && npm run publish:verify-ignore-scripts --silent && node ./dist/scripts/release-registry-check.js --require-unpublished --require-publish-auth --require-pack-proof && node ./dist/scripts/release-check-stamp.js verify",
    "publish:ignore-scripts": "npm run publish:prep-ignore-scripts && npm publish --ignore-scripts",
    "gates:run": "node ./dist/scripts/release-gate-dag-runner.js",
    "policy:gate-audit": "node ./dist/scripts/gate-policy-audit-check.js",
    "release:dag-full-coverage": "node ./dist/scripts/release-dag-full-coverage-check.js",
    "core-skill:route-runtime-integration": "node ./dist/scripts/core-skill-route-runtime-integration-check.js",
    "competitor:scorecard": "node ./dist/scripts/competitor-scorecard-check.js",
    "runtime:installed-smoke": "node ./dist/scripts/installed-package-smoke-check.js",
    "perf:budgets": "node ./dist/scripts/perf-budget-check.js",
    "runtime:import-budget": "node ./dist/scripts/import-graph-budget-check.js",
    "fsx:hotpath": "node ./dist/scripts/fsx-hotpath-check.js",
    "hook:latency-quantum": "node ./dist/scripts/hook-latency-quantum-check.js",
    "doctor:fastpath": "node ./dist/scripts/doctor-fastpath-check.js",
    "doctor:ops-semantics": "node ./dist/scripts/doctor-ops-semantics-check.js",
    "update:fastpath": "node ./dist/scripts/update-fastpath-check.js",
    "parallel:production-smoke": "node ./dist/scripts/parallel-production-smoke-check.js",
    "naruto:e2e-hermetic": "node ./dist/scripts/naruto-codex-e2e-check.js --mode hermetic",
    "naruto:e2e-real-codex": "node ./dist/scripts/naruto-codex-e2e-check.js --mode real-codex",
    "naruto:e2e-hermetic-write": "node ./dist/scripts/naruto-write-e2e-check.js --mode hermetic",
    "naruto:e2e-real-write": "node ./dist/scripts/naruto-write-e2e-check.js --mode real-codex",
    "super-search:offline-contract": "node ./dist/scripts/super-search-offline-contract-check.js",
    "super-search:local-http-smoke": "node ./dist/scripts/super-search-local-http-smoke-check.js",
    "super-search:live-smoke": "node ./dist/scripts/super-search-live-smoke-check.js",
    "seo:metadata-sync": "node ./dist/scripts/seo-metadata-sync-check.js",
    "seo:marketing-truthfulness": "node ./dist/scripts/seo-marketing-truthfulness-check.js",
    "doctor:idempotence": "node ./dist/scripts/doctor-idempotence-check.js",
    "retention:budget": "node ./dist/scripts/retention-budget-check.js",
    "retention:dry-run": "node ./dist/scripts/retention-dry-run-check.js",
    "retention:apply-smoke": "node ./dist/scripts/retention-apply-smoke-check.js",
    "upgrade:migration-matrix": "node ./dist/scripts/upgrade-migration-matrix-check.js",
    "recovery:rollback-smoke": "node ./dist/scripts/rollback-recovery-smoke-check.js",
    "ops:diagnostics-bundle": "node ./dist/scripts/ops-diagnostics-bundle-check.js",
    "security:high-risk-contracts": "node ./dist/scripts/high-risk-contracts-check.js",
    "route:intent-regression": "node ./dist/scripts/route-intent-regression-check.js"
  },
  "keywords": [
    "sneakoscope",
    "codex",
    "sks",
    "codex-cli",
    "codex-app",
    "agent-orchestration",
    "proof-gates",
    "super-search",
    "seo",
    "generative-engine-optimization",
    "bounded-memory",
    "rollback",
    "release-integrity"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex-sdk": "0.144.1",
    "figlet": "^1.11.0",
    "smol-toml": "^1.7.0",
    "typescript": "^5.9.3"
  },
