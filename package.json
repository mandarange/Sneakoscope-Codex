{
  "name": "sneakoscope",
  "displayName": "ㅅㅋㅅ",
  "version": "0.7.73",
  "description": "Sneakoscope Codex: database-safe Codex CLI/App harness with Team, Goal, AutoResearch, TriWiki, and Honest Mode.",
  "type": "module",
  "homepage": "https://github.com/mandarange/Sneakoscope-Codex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandarange/Sneakoscope-Codex.git"
  },
  "bugs": {
    "url": "https://github.com/mandarange/Sneakoscope-Codex/issues"
  },
  "bin": {
    "sks": "bin/sks.mjs",
    "sneakoscope": "bin/sks.mjs"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "repo-audit": "node ./scripts/repo-audit.mjs",
    "postinstall": "node ./bin/sks.mjs postinstall",
    "selftest": "node ./bin/sks.mjs selftest --mock",
    "doctor": "node ./bin/sks.mjs doctor",
    "packcheck": "find bin src scripts -name '*.mjs' -print0 | xargs -0 -n1 node --check",
    "changelog:check": "node ./scripts/changelog-check.mjs",
    "sizecheck": "node ./scripts/sizecheck.mjs",
    "registry:check": "node ./scripts/release-registry-check.mjs",
    "release:check": "npm run repo-audit && npm run changelog:check && npm run packcheck && npm run selftest && npm run sizecheck && npm run registry:check",
    "publish:dry": "npm run release:check && npm --cache /tmp/sks-npm-cache publish --dry-run --registry https://registry.npmjs.org/ --access public",
    "publish:npm": "npm --cache /tmp/sks-npm-cache publish --registry https://registry.npmjs.org/ --access public",
    "prepublishOnly": "npm run release:check && node ./scripts/release-registry-check.mjs --require-unpublished"
  },
  "keywords": [
    "sneakoscope",
    "codex",
    "sks",
    "openai",
    "openai-codex",
    "openclaw",
    "openclaw-skill",
    "cli",
    "developer-tools",
    "ai-coding",
    "ai-agent",
    "ai-agents",
    "agentic-coding",
    "harness",
    "codex-cli",
    "codex-app",
    "tmux",
    "auto-review",
    "browser-use",
    "computer-use",
    "codex-hooks",
    "multi-agent",
    "subagents",
    "agent-orchestration",
    "prompt-router",
    "goal",
    "research",
    "autoresearch",
    "honest-mode",
    "update-check",
    "llm-wiki",
    "wiki-coordinate",
    "gx",
    "visual-context",
    "database-safe",
    "supabase-mcp",
    "bounded-memory",
    "intentional-forgetting",
    "skill-forge",
    "code-structure",
    "storage-safe",
    "rust-optional",
    "supabase",
    "mcp-safety",
    "db-guardian"
  ],
  "license": "MIT",
  "dependencies": {
    "figlet": "^1.11.0"
  }
}
