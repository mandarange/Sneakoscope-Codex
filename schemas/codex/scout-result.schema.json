{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sneakoscope.local/schemas/codex/scout-result.schema.json",
  "title": "SKS Scout Result",
  "type": "object",
  "required": [
    "schema",
    "mission_id",
    "scout_id",
    "role",
    "route",
    "status",
    "read_only",
    "write_policy",
    "generated_at",
    "summary",
    "findings",
    "suggested_tasks",
    "blockers",
    "unverified",
    "context7_required",
    "context7_libraries",
    "required_image_voxel_evidence",
    "engine_run_id",
    "scout_session_id",
    "session_id",
    "resume_id",
    "engine",
    "engine_mode",
    "real_parallel",
    "output_schema_used",
    "output_schema_path",
    "schema_validation",
    "session_lifecycle",
    "source_file",
    "stdout_file",
    "stderr_file",
    "parse_issues",
    "blocked_reason",
    "read_only_confirmed",
    "artifact_namespace"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "string", "const": "sks.scout-result.v3" },
    "mission_id": { "type": ["string", "null"] },
    "scout_id": { "type": "string", "minLength": 1 },
    "role": { "type": ["string", "null"] },
    "route": { "type": ["string", "null"] },
    "status": { "type": ["string", "null"], "enum": ["done", "blocked", "partial", null] },
    "read_only": { "type": "boolean", "const": true },
    "write_policy": { "type": ["string", "null"] },
    "generated_at": { "type": ["string", "null"] },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "claim", "evidence", "risk", "severity", "confidence", "files", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk": { "type": "string", "minLength": 1 },
          "severity": { "type": ["string", "null"] },
          "confidence": { "type": ["number", "null"] },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "suggested_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "files", "verification", "risk", "owner", "notes"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "verification": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk": { "type": ["string", "null"] },
          "owner": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unverified": {
      "type": "array",
      "items": { "type": "string" }
    },
    "context7_required": { "type": "boolean" },
    "context7_libraries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_image_voxel_evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "engine_run_id": { "type": ["string", "null"] },
    "scout_session_id": { "type": ["string", "null"] },
    "session_id": { "type": ["string", "null"] },
    "resume_id": { "type": ["string", "null"] },
    "engine": { "type": ["string", "null"] },
    "engine_mode": {
      "type": ["string", "null"],
      "enum": ["local_static", "codex_exec", "codex_exec_resume_schema", "tmux_lane", "codex_app_subagent", "sequential_fallback", "fake_codex_exec", "unknown", null]
    },
    "real_parallel": { "type": "boolean" },
    "output_schema_used": { "type": "boolean" },
    "output_schema_path": { "type": ["string", "null"] },
    "schema_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "schema", "issues", "migrated_from_schema"],
      "properties": {
        "ok": { "type": "boolean" },
        "schema": { "type": ["string", "null"] },
        "issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "migrated_from_schema": { "type": ["string", "null"] }
      }
    },
    "session_lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "started_at", "completed_at", "timeout", "session_id", "resume_id", "lane_id"],
      "properties": {
        "status": { "type": ["string", "null"] },
        "started_at": { "type": ["string", "null"] },
        "completed_at": { "type": ["string", "null"] },
        "timeout": { "type": "boolean" },
        "session_id": { "type": ["string", "null"] },
        "resume_id": { "type": ["string", "null"] },
        "lane_id": { "type": ["string", "null"] }
      }
    },
    "source_file": { "type": ["string", "null"] },
    "stdout_file": { "type": ["string", "null"] },
    "stderr_file": { "type": ["string", "null"] },
    "parse_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocked_reason": { "type": ["string", "null"] },
    "read_only_confirmed": { "type": "boolean" },
    "artifact_namespace": { "type": ["string", "null"] }
  }
}
