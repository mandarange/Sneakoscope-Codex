{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sneakoscope.local/schemas/codex/scout-result.schema.json",
  "title": "SKS Scout Result",
  "type": "object",
  "required": ["schema", "scout_id", "findings", "suggested_tasks"],
  "properties": {
    "schema": { "const": "sks.scout-result.v1" },
