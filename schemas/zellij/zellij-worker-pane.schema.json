{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sneakoscope.local/schemas/zellij/zellij-worker-pane.schema.json",
  "title": "SKS Zellij Worker Pane",
  "type": "object",
  "required": [
    "schema",
    "ok",
    "status",
    "session_name",
    "slot_id",
    "generation_index",
    "session_id",
    "pane_name",
    "pane_kind",
    "pane_id",
    "pane_id_source",
    "worker_artifact_dir",
    "worker_result_path",
    "heartbeat_path",
    "parent_child_transport",
    "scaling_primitive",
    "blockers"
  ],
  "properties": {
    "schema": { "const": "sks.zellij-worker-pane.v1" },
    "ok": { "type": "boolean" },
    "status": { "enum": ["launching", "running", "closed", "failed"] },
    "session_name": { "type": "string", "minLength": 1 },
    "slot_id": { "type": "string", "pattern": "^slot-[0-9]{3}$" },
    "generation_index": { "type": "integer", "minimum": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "pane_name": { "type": "string", "pattern": "^slot-[0-9]{3}/gen-[0-9]+$" },
    "pane_kind": { "const": "worker_codex_cli" },
    "pane_id": { "type": ["string", "null"] },
    "pane_id_source": {
      "enum": [
        "zellij_worker_new_pane_stdout",
        "zellij_worker_list_panes",
        "zellij_worker_pane_stdout_missing",
        "zellij_worker_pane_launch_failed"
      ]
    },
    "worker_artifact_dir": { "type": "string", "minLength": 1 },
    "worker_result_path": { "type": "string", "minLength": 1 },
    "heartbeat_path": { "type": "string", "minLength": 1 },
    "patch_envelope_path": { "type": "string" },
    "parent_child_transport": { "const": "worker-result-json-and-heartbeat" },
    "scaling_primitive": { "const": "native_cli_process_in_zellij_worker_pane" },
    "blockers": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
