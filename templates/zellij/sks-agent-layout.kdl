layout {
    tab name="SKS Official Subagents" split_direction="vertical" {
        pane name="orchestrator" command="sh" {
            args "-lc" "sks naruto status latest --json; exec ${SHELL:-/bin/zsh}"
        }
        pane split_direction="horizontal" size="38%" {
            pane name="subagent-monitor" command="sks" {
                args "zellij-monitor-pane" "--mission" "latest" "--interval-ms" "1000" "--watch"
            }
            pane name="viewport-1" command="sks" {
                args "zellij-viewport-pane" "--mission" "latest" "--index" "1" "--of" "1" "--interval-ms" "1000" "--watch"
            }
        }
    }
}
